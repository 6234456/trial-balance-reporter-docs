{
  "name": "trial-balance-reporter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "generate:fixtures": "tsx scripts/generate-fixtures.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "d3": "latest",
    "decimal.js": "latest",
    "react": "latest",
    "react-dom": "latest",
    "reveal.js": "latest",
    "vite": "latest",
    "xlsx": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/d3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-react-hooks": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "prettier": "latest",
    "tailwindcss": "3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
